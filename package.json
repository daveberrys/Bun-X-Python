{
  "name": "bunxpythontest",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "workspaces": ["src", "web"],
  "scripts": {
    "build:web": "bun run --filter web build",
    "build:py": "src/venv/Scripts/pyinstaller build.spec --clean --noconfirm",
    
    "dev": "bun run --filter '*' dev",
    "pip": "bun run --filter src pip",
    "init": "bun run --filter src init",
    "build": "bun run build:web && bun run build:py",
    "kill": "echo \"Killing thrice...\" && npx kill-port 5173 && npx kill-port 5173 && npx kill-port 5173 && echo \"Done!\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "bun@1.3.5"
}
